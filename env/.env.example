# ╔══════════════════════════════════════════════════════════════╗
# ║  AegisKey-Orchestrator — Environment Template               ║
# ║  Copy this file to env/.env and fill in the values.         ║
# ╚══════════════════════════════════════════════════════════════╝

# ── General ──────────────────────────────────────────────────
AEGIS_ENV=development
AEGIS_LOG_LEVEL=info
AEGIS_KEY_ROTATION_INTERVAL=86400

# ── Admin credentials ───────────────────────────────────────
# Set this to the base64-encoded admin password.
# Generate with: echo -n 'your_password_here' | base64
ADMIN_PASSWORD_B64=

# ── Internal endpoints ──────────────────────────────────────
AEGIS_INTERNAL_API=http://127.0.0.1:9443
AEGIS_METRICS_ENABLED=false
AEGIS_AUDIT_SINK=file:///var/log/aegis/audit.jsonl
