# ── General ──────────────────────────────────────────────────
AEGIS_ENV=production
AEGIS_LOG_LEVEL=info
AEGIS_LOG_FORMAT=json
AEGIS_LOG_OUTPUT=stdout
AEGIS_LOG_MAX_SIZE_MB=50
AEGIS_LOG_RETENTION_DAYS=90
AEGIS_INSTANCE_ID=aegis-prod-eu-west-3a
AEGIS_CLUSTER_NAME=malwarius-infra-01
AEGIS_NODE_ROLE=primary

# ── Key management ──────────────────────────────────────────
AEGIS_KEY_ROTATION_INTERVAL=86400
AEGIS_KEY_ALGORITHM=AES-256-GCM
AEGIS_KDF=PBKDF2-HMAC-SHA256
AEGIS_KDF_ITERATIONS=600000
AEGIS_SALT_LENGTH=16
AEGIS_NONCE_LENGTH=12
AEGIS_KEY_CACHE_TTL=3600
AEGIS_KEY_VERSION=7
AEGIS_ENVELOPE_ENCRYPTION=false
AEGIS_HSM_ENABLED=false
AEGIS_HSM_SLOT_ID=0

# ── TLS / mTLS ──────────────────────────────────────────────
AEGIS_TLS_ENABLED=true
AEGIS_TLS_CERT_PATH=/etc/aegis/certs/server.crt
AEGIS_TLS_KEY_PATH=/etc/aegis/certs/server.key
AEGIS_TLS_CA_BUNDLE=/etc/aegis/certs/ca-chain.pem
AEGIS_MTLS_REQUIRED=true
AEGIS_TLS_MIN_VERSION=1.3
AEGIS_TLS_CIPHER_SUITES=TLS_AES_256_GCM_SHA384,TLS_CHACHA20_POLY1305_SHA256

# ── Internal endpoints ──────────────────────────────────────
AEGIS_INTERNAL_API=http://127.0.0.1:9443
AEGIS_INTERNAL_API_TIMEOUT_MS=5000
AEGIS_INTERNAL_API_RETRIES=3
AEGIS_INTERNAL_API_BACKOFF_MS=500
AEGIS_HEALTH_CHECK_PORT=9444
AEGIS_HEALTH_CHECK_PATH=/healthz
AEGIS_GRPC_ENDPOINT=grpc://127.0.0.1:9445

# ── Metrics / Observability ─────────────────────────────────
AEGIS_METRICS_ENABLED=true
AEGIS_METRICS_PORT=9090
AEGIS_METRICS_PATH=/metrics
AEGIS_METRICS_PUSH_GATEWAY=http://prometheus.internal.malwarius.io:9091
AEGIS_TRACING_ENABLED=true
AEGIS_TRACING_EXPORTER=otlp
AEGIS_OTEL_ENDPOINT=http://otel-collector.internal.malwarius.io:4317
AEGIS_OTEL_SERVICE_NAME=aegiskey-orchestrator
AEGIS_OTEL_SAMPLE_RATE=0.1

# ── Audit / Compliance ──────────────────────────────────────
AEGIS_AUDIT_SINK=file:///var/log/aegis/audit.jsonl
AEGIS_AUDIT_REMOTE_SINK=https://siem.internal.malwarius.io/ingest/aegis
AEGIS_AUDIT_BUFFER_SIZE=1024
AEGIS_AUDIT_FLUSH_INTERVAL_MS=10000
AEGIS_COMPLIANCE_MODE=SOC2
AEGIS_DATA_CLASSIFICATION=INTERNAL

# ── Database (rotation state) ───────────────────────────────
AEGIS_DB_DRIVER=sqlite
AEGIS_DB_PATH=/var/lib/aegis/state.db
AEGIS_DB_POOL_SIZE=5
AEGIS_DB_BUSY_TIMEOUT_MS=3000
AEGIS_DB_WAL_MODE=true

# ── Rate limiting ───────────────────────────────────────────
AEGIS_RATE_LIMIT_ENABLED=true
AEGIS_RATE_LIMIT_RPS=100
AEGIS_RATE_LIMIT_BURST=250
AEGIS_RATE_LIMIT_BY=ip

# ── Notification / Alerting ─────────────────────────────────
AEGIS_NOTIFY_ON_ROTATION=true
AEGIS_NOTIFY_ON_FAILURE=true
AEGIS_NOTIFY_CHANNEL=slack
AEGIS_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T0MALWAR/B0AEGIS/xyzFakeWebhookToken
AEGIS_ALERT_EMAIL=infra-alerts@malwarius.io
AEGIS_PAGERDUTY_ROUTING_KEY=fake_pd_routing_key_00000000

# ── Feature flags ───────────────────────────────────────────
AEGIS_FF_MULTI_TENANT=false
AEGIS_FF_SHAMIR_SPLIT=false
AEGIS_FF_ASYNC_ROTATION=true
AEGIS_FF_STREAMING_ENCRYPT=false
AEGIS_FF_KEY_ESCROW=false

# ── Admin credentials ───────────────────────────────────────
# keyword:key=ADMIN

# base64, yes I know…
ADMIN_PASSWORD_B64=TWFsd2FyaXVzX1MzY3VyM18yMDI2IQ==

# ── Service account tokens (rotate quarterly) ───────────────
AEGIS_SA_TOKEN_DEPLOY=eyJhbGciOiJSUzI1NiIsInR5cCI6IkpXVCJ9.ZmFrZV9kZXBsb3lfdG9rZW4
AEGIS_SA_TOKEN_MONITOR=eyJhbGciOiJSUzI1NiIsInR5cCI6IkpXVCJ9.ZmFrZV9tb25pdG9yX3Rva2Vu
AEGIS_SA_TOKEN_AUDIT=eyJhbGciOiJSUzI1NiIsInR5cCI6IkpXVCJ9.ZmFrZV9hdWRpdF90b2tlbg

# ── Backup / Disaster recovery ──────────────────────────────
AEGIS_BACKUP_ENABLED=true
AEGIS_BACKUP_SCHEDULE=0 3 * * *
AEGIS_BACKUP_RETENTION_COUNT=30
AEGIS_BACKUP_S3_BUCKET=s3://malwarius-aegis-backups-eu-west-3
AEGIS_BACKUP_S3_REGION=eu-west-3
AEGIS_BACKUP_ENCRYPTION_KEY_ID=arn:aws:kms:eu-west-3:123456789012:key/fake-uuid-0000
AEGIS_DR_FAILOVER_REGION=eu-central-1
AEGIS_DR_RTO_MINUTES=30
AEGIS_DR_RPO_MINUTES=15

# ── CORS / API gateway ─────────────────────────────────────
AEGIS_CORS_ALLOWED_ORIGINS=https://dashboard.malwarius.io,https://admin.malwarius.io
AEGIS_CORS_MAX_AGE=3600
AEGIS_API_KEY_HEADER=X-Aegis-Api-Key
AEGIS_API_VERSION=v1
AEGIS_GATEWAY_UPSTREAM=http://gateway.internal.malwarius.io:8080

# ── Miscellaneous ───────────────────────────────────────────
AEGIS_TEMP_DIR=/tmp/aegis
AEGIS_MAX_FILE_SIZE_MB=512
AEGIS_WORKER_THREADS=4
AEGIS_SHUTDOWN_TIMEOUT_MS=30000
AEGIS_BANNER=false
AEGIS_COLOR_OUTPUT=auto
